<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="DisBlox.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:DisBlox"
    xmlns:services="using:DisBlox.Services"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24" ColumnSpacing="24" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="280" />
        </Grid.ColumnDefinitions>

        <Button
            Grid.Row="0"
            Grid.Column="1"
            HorizontalAlignment="Right"
            Click="SettingsButton_Click"
            ToolTipService.ToolTip="Edit RoVer / BloxLink API keys">
            <FontIcon Glyph="&#xE713;" FontSize="16" />
        </Button>

        <StackPanel Grid.Row="1" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16" Width="320">
            <TextBlock
                Text="DisBlox"
                Style="{StaticResource TitleTextBlockStyle}"
                HorizontalAlignment="Center" />

            <TextBox
                x:Name="UsernameBox"
                Header="Roblox Username"
                PlaceholderText="e.g. Builderman"
                Text="{x:Bind ViewModel.RobloxUsername, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                TextChanged="UsernameBox_TextChanged" />

            <ListView
                x:Name="SuggestionsList"
                ItemsSource="{x:Bind ViewModel.UsernameSuggestions, Mode=OneWay}"
                MaxHeight="180"
                SelectionMode="None"
                IsItemClickEnabled="True"
                ItemClick="SuggestionsList_ItemClick">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="services:RobloxUserSuggestion">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" />
                            <TextBlock Text="{x:Bind DisplayName}" Opacity="0.6" />
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <TextBlock HorizontalAlignment="Center">
                <Run Text="Chosen Username: " FontWeight="SemiBold" />
                <Run Text="{x:Bind ViewModel.ChosenUsername, Mode=OneWay}" />
            </TextBlock>

            <Button
                Content="Search"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                Command="{x:Bind ViewModel.SearchCommand}" />

            <ProgressBar
                Value="{x:Bind ViewModel.SearchProgress, Mode=OneWay}"
                Maximum="100" />

            <TextBlock
                Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                TextWrapping="Wrap"
                HorizontalAlignment="Center"
                Style="{StaticResource BodyTextBlockStyle}" />

            <TextBlock
                Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                TextWrapping="Wrap"
                HorizontalAlignment="Center"
                Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                Style="{StaticResource BodyTextBlockStyle}" />
        </StackPanel>

        <Border
            Grid.Row="1"
            Grid.Column="1"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="12">
            <StackPanel Spacing="8">
                <TextBlock Text="Server To Search" Style="{StaticResource SubtitleTextBlockStyle}" />

                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBox
                        Width="160"
                        PlaceholderText="Guild ID"
                        Text="{x:Bind ViewModel.NewGuildId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Content="Add" Command="{x:Bind ViewModel.AddGuildCommand}" />
                </StackPanel>

                <ListView ItemsSource="{x:Bind ViewModel.GuildIds, Mode=OneWay}" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{x:Bind}" VerticalAlignment="Center" />
                                <Button Grid.Column="1" Content="✕" Tag="{x:Bind}" Click="RemoveGuildButton_Click" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </Border>
    </Grid>
</Page>
