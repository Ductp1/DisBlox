<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="DisBlox.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:DisBlox"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16" Width="320">
        <TextBlock
            Text="DisBlox Setup"
            Style="{StaticResource TitleTextBlockStyle}"
            HorizontalAlignment="Center" />

        <TextBox
            Header="Roblox Username"
            PlaceholderText="e.g. Builderman"
            Text="{x:Bind ViewModel.RobloxUsername, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <Button
            Content="Connect Bot"
            HorizontalAlignment="Stretch"
            HorizontalContentAlignment="Center"
            Command="{x:Bind ViewModel.ConnectCommand}" />

        <ProgressRing IsActive="{x:Bind ViewModel.IsConnecting, Mode=OneWay}" HorizontalAlignment="Center" />

        <TextBlock
            Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
            TextWrapping="Wrap"
            HorizontalAlignment="Center"
            Style="{StaticResource BodyTextBlockStyle}" />
    </StackPanel>
</Page>
