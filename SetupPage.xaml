<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="DisBlox.SetupPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:DisBlox"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16" Width="380">
        <TextBlock
            Text="Connect DisBlox"
            Style="{StaticResource TitleTextBlockStyle}"
            HorizontalAlignment="Center" />

        <TextBlock
            Text="Enter at least one API key so DisBlox can look up Discord accounts linked through RoVer or BloxLink."
            TextWrapping="Wrap"
            Style="{StaticResource BodyTextBlockStyle}" />

        <PasswordBox
            x:Name="RoverKeyBox"
            Header="RoVer Bot Developer API Key (optional)"
            PasswordChanged="RoverKeyBox_PasswordChanged" />

        <PasswordBox
            x:Name="BloxLinkKeyBox"
            Header="BloxLink Developer API Key (optional)"
            PasswordChanged="BloxLinkKeyBox_PasswordChanged" />

        <TextBlock
            Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
            TextWrapping="Wrap"
            Foreground="{ThemeResource SystemFillColorCriticalBrush}" />

        <Button
            Content="Continue"
            HorizontalAlignment="Stretch"
            HorizontalContentAlignment="Center"
            Command="{x:Bind ViewModel.ContinueCommand}" />
    </StackPanel>
</Page>
